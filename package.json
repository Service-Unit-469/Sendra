{
  "name": "sendra",
  "version": "0.1.0",
  "private": true,
  "license": "agpl-3.0",
  "engines": {
    "node": ">=20.x",
    "npm": ">=9.8.x"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@playwright/test": "^1.58.2",
    "@pulumi/aws": "^7.23.0",
    "@testing-library/dom": "^10.4.1",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^29.0.2",
    "rimraf": "^6.1.3",
    "vitest": "^4.0.15"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "build:deps": "npm run build --w=packages/test && npm run build --w=packages/shared && npm run build --w=packages/lib",
    "clean": "npm run clean --workspaces",
    "deploy": "sst deploy",
    "deploy:integration": "npm run deploy && npm run test:e2e --workspace=@sendra/dashboard",
    "deploy:integration:ui": "npm run deploy && npm run test:e2e:ui --workspace=@sendra/dashboard",
    "dev": "npm run build:deps && sst dev",
    "lint": "npm run lint --workspaces",
    "lint:fix": "npm run lint  --workspaces -- --write",
    "remove": "sst remove",
    "sst": "sst",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces"
  },
  "workspaces": [
    "packages/test",
    "packages/shared",
    "packages/lib",
    "packages/api",
    "packages/subscribers",
    "packages/dashboard",
    "packages/subscription"
  ],
  "dependencies": {
    "sst": "^3.18.6"
  },
  "overrides": {
    "hono": "^4.10.4",
    "zod": "^4.1.11",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "packageManager": "pnpm@10.27.0+sha512.72d699da16b1179c14ba9e64dc71c9a40988cbdc65c264cb0e489db7de917f20dcf4d64d8723625f2969ba52d4b7e2a1170682d9ac2a5dcaeaab732b7e16f04a"
}
