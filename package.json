{
  "name": "sendra",
  "version": "0.1.0",
  "private": true,
  "license": "agpl-3.0",
  "engines": {
    "node": ">=20.x",
    "pnpm": ">=10.x"
  },
  "packageManager": "pnpm@10.13.1",
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@playwright/test": "^1.61.1",
    "@pulumi/aws": "^7.34.0",
    "@testing-library/dom": "^10.4.1",
    "@types/node": "^24.13.1",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "rimraf": "^6.1.3",
    "turbo": "^2.5.8",
    "vitest": "^4.0.15"
  },
  "scripts": {
    "build": "turbo run build --filter=!sendra",
    "build:deps": "turbo run build --filter=...@sendra/dashboard",
    "clean": "turbo run clean --filter=!sendra",
    "deploy": "sst deploy",
    "deploy:integration": "pnpm run deploy && pnpm --filter @sendra/dashboard test:e2e",
    "deploy:integration:ui": "pnpm run deploy && pnpm --filter @sendra/dashboard test:e2e:ui",
    "dev": "pnpm run build:deps && sst dev",
    "lint": "turbo run lint --filter=!sendra",
    "lint:fix": "turbo run lint:fix --filter=!sendra",
    "remove": "sst remove",
    "sst": "sst",
    "test": "turbo run test --filter=!sendra",
    "typecheck": "turbo run typecheck --filter=!sendra",
    "wait:deployment": "node scripts/wait-for-deployment-readiness.mjs"
  },
  "workspaces": [
    "packages/test",
    "packages/shared",
    "packages/lib",
    "packages/api",
    "packages/subscribers",
    "packages/dashboard",
    "packages/subscription"
  ],
  "dependencies": {
    "sst": "^4.15.2"
  },
  "overrides": {
    "hono": "^4.10.4",
    "zod": "^4.1.11",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  }
}
