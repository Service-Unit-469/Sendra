{
  "name": "sendra",
  "version": "0.1.0",
  "private": true,
  "license": "agpl-3.0",
  "engines": {
    "node": ">=20.x",
    "pnpm": ">=10.x"
  },
  "packageManager": "pnpm@10.13.1",
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@playwright/test": "catalog:",
    "@pulumi/aws": "catalog:",
    "@pulumi/pulumi": "^3.249.0",
    "@testing-library/dom": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "jsdom": "catalog:",
    "rimraf": "catalog:",
    "turbo": "catalog:",
    "vitest": "catalog:"
  },
  "scripts": {
    "build": "turbo run build --filter=!sendra",
    "build:deps": "turbo run build --filter=...@sendra/dashboard",
    "clean": "turbo run clean --filter=!sendra",
    "deploy": "sst deploy",
    "deploy:integration": "pnpm run deploy && pnpm --filter @sendra/dashboard test:e2e",
    "deploy:integration:ui": "pnpm run deploy && pnpm --filter @sendra/dashboard test:e2e:ui",
    "dev": "pnpm run build:deps && sst dev",
    "lint": "turbo run lint --filter=!sendra",
    "lint:fix": "turbo run lint:fix --filter=!sendra",
    "remove": "sst remove",
    "sst": "sst",
    "test": "turbo run test --filter=!sendra --concurrency 1",
    "typecheck": "turbo run typecheck --filter=!sendra",
    "wait:deployment": "node scripts/wait-for-deployment-readiness.mjs"
  },
  "workspaces": [
    "packages/test",
    "packages/shared",
    "packages/lib",
    "packages/api",
    "packages/subscribers",
    "packages/dashboard",
    "packages/subscription"
  ],
  "dependencies": {
    "sst": "catalog:",
    "zod": "catalog:"
  },
  "overrides": {
    "hono": "^4.10.4",
    "zod": "^4.1.11",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  }
}
