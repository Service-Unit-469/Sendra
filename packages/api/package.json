{
	"name": "@sendra/api",
	"version": "1.0.0",
	"main": "dist/index.js",
	"private": true,
	"scripts": {
		"build": "tsc && pnpm run openapi:export && pnpm run openapi:validate",
		"lint": "biome check src",
		"lint:fix": "biome check --write src",
		"lint:fix:unsafe": "biome check --write src --unsafe",
		"typecheck": "tsc --noEmit",
		"clean": "rimraf dist",
		"test": "vitest run",
		"test:watch": "vitest",
		"openapi:export": "tsx scripts/export-openapi.ts",
		"openapi:validate": "pnpm --package=@seriousme/openapi-schema-validator dlx validate-api ../../docs/openapi.json"
	},
	"devDependencies": {
		"@sendra/test": "workspace:*",
		"@types/compression": "catalog:",
		"@types/jsonwebtoken": "catalog:",
		"@types/ms": "^2.1.0",
		"sst": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"dependencies": {
		"@aws-sdk/client-dynamodb": "catalog:",
		"@aws-sdk/client-s3": "catalog:",
		"@aws-sdk/client-ses": "catalog:",
		"@aws-sdk/lib-dynamodb": "catalog:",
		"@aws-sdk/s3-request-presigner": "catalog:",
		"@hono/zod-openapi": "catalog:",
		"@sendra/lib": "workspace:*",
		"@sendra/shared": "workspace:*",
		"ajv": "catalog:",
		"ajv-formats": "catalog:",
		"aws-embedded-metrics": "catalog:",
		"dayjs": "catalog:",
		"hono": "catalog:",
		"hono-pino": "catalog:",
		"jsonwebtoken": "catalog:",
		"lru-cache": "^11.5.1",
		"ms": "^2.1.3",
		"zod": "catalog:"
	}
}
