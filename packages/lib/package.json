{
  "name": "@sendra/lib",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": true,
  "dependencies": {
    "@aws-sdk/client-dynamodb": "catalog:",
    "@aws-sdk/client-s3": "catalog:",
    "@aws-sdk/client-ses": "catalog:",
    "@aws-sdk/client-sfn": "catalog:",
    "@aws-sdk/client-sqs": "catalog:",
    "@aws-sdk/lib-dynamodb": "catalog:",
    "@aws-sdk/s3-request-presigner": "catalog:",
    "@aws-sdk/util-dynamodb": "^3.996.5",
    "@sendra/shared": "workspace:*",
    "aws-embedded-metrics": "catalog:",
    "handlebars": "catalog:",
    "mail-mime-builder": "catalog:",
    "pino": "catalog:",
    "pino-pretty": "catalog:",
    "uuidv7": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@sendra/test": "workspace:*",
    "sst": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "scripts": {
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "lint:fix:unsafe": "biome check --write src --unsafe",
